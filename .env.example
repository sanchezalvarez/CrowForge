# CrowForge Server Configuration
# Copy this file to .env and fill in your values

# Deployment mode: host = team server, local = single PC
CROWFORGE_DEPLOYMENT_MODE=host

# API key for client authentication
# Generate a strong random key — clients need this to connect
CROWFORGE_HOST_API_KEY=sk-cf-changeme

# Port to expose (default: 8000)
CROWFORGE_HOST_PORT=8000

# Log level: INFO, DEBUG, WARNING
CROWFORGE_LOG_LEVEL=INFO
