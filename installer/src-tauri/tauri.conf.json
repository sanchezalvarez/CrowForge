{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrowForge-Install",
  "version": "0.4.6",
  "identifier": "com.lubot.crowforge.installer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "CrowForge",
        "width": 480,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
